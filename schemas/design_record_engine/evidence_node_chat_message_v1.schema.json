{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ovc.local/schemas/design_record_engine/evidence_node_chat_message_v1.schema.json",
  "title": "Evidence Node Chat Message v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chat_id",
    "content_sha256",
    "export_id",
    "message_id",
    "node_id",
    "shard_file",
    "shard_line_number",
    "type"
  ],
  "properties": {
    "chat_id": {
      "type": "string",
      "minLength": 1
    },
    "content_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "export_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "shard_file": {
      "type": "string",
      "minLength": 1
    },
    "shard_line_number": {
      "type": "integer",
      "minimum": 1
    },
    "type": {
      "type": "string",
      "const": "chat_message"
    }
  }
}
